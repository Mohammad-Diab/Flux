<UserControl x:Class="FluxCast.Views.EncodeProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="580" Margin="32" VerticalAlignment="Center">
        <Border Style="{StaticResource Card}" Padding="28">
            <StackPanel>
                <TextBlock Text="{Binding PhaseText}" Style="{StaticResource HeadingText}"/>
                <ProgressBar Height="8" Margin="0,20,0,10"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Minimum="0" Maximum="1" Value="{Binding ProgressValue, Mode=OneWay}"/>
                <TextBlock Text="{Binding DetailText}" Style="{StaticResource SubtleText}"/>

                <TextBlock Text="{Binding ErrorText}" FontSize="13" Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" Margin="0,16,0,0"
                           Visibility="{Binding ErrorText, Converter={StaticResource NullToCollapsed}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                    <Button Content="Back" Command="{Binding AcknowledgeErrorCommand}"
                            Visibility="{Binding ErrorText, Converter={StaticResource NullToCollapsed}}"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
