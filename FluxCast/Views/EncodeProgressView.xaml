<UserControl x:Class="FluxCast.Views.EncodeProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="560" Margin="32" VerticalAlignment="Center">
        <StackPanel>
            <TextBlock Text="{Binding PhaseText}" FontSize="26" FontWeight="Light"/>
            <ProgressBar Height="10" Margin="0,20,0,8"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Minimum="0" Maximum="1" Value="{Binding ProgressValue, Mode=OneWay}"/>
            <TextBlock Text="{Binding DetailText}" FontSize="13" Foreground="Gray"/>

            <TextBlock Text="{Binding ErrorText}" FontSize="13" Foreground="#C62828"
                       TextWrapping="Wrap" Margin="0,16,0,0"
                       Visibility="{Binding ErrorText, Converter={StaticResource NullToCollapsed}}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                <Button Content="Back" Command="{Binding AcknowledgeErrorCommand}" Padding="24,8"
                        Visibility="{Binding ErrorText, Converter={StaticResource NullToCollapsed}}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="24,8" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
