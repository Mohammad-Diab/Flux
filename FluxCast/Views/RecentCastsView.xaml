<UserControl x:Class="FluxCast.Views.RecentCastsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,16,0,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="26,0,26,14">
            <TextBlock Text="Recent casts" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Resume a past cast, open its source location, or delete it to free space."
                       Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="42"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="No casts yet" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="Cast a file or folder and it'll show up here." Style="{StaticResource SubtleText}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <!-- Cards are inset so their drop shadows have room before the scroll-viewer clip. -->
            <ItemsControl ItemsSource="{Binding Casts}" Margin="24,8,24,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                        Background="{StaticResource SurfaceAltBrush}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border HorizontalAlignment="Left" Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="5" Padding="7,2" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SpecText}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    <TextBlock Text="{Binding LocationText}" Style="{StaticResource SubtleText}"
                                               FontSize="12" Opacity="0.75" TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0" ToolTip="{Binding LocationText}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding FramesText}" Style="{StaticResource SubtleText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" Style="{StaticResource SubtleText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding DateText}" Style="{StaticResource SubtleText}"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button Content="Resume" Style="{StaticResource PrimaryButton}"
                                            MinHeight="0" Padding="18,8" FontSize="12.5" Effect="{x:Null}"
                                            Command="{Binding ResumeCommand}" ToolTip="{Binding ResumeTooltip}"/>
                                    <Button Content="Open location" Style="{StaticResource SecondaryButton}"
                                            MinHeight="0" Padding="14,8" FontSize="12.5" Margin="8,0,0,0"
                                            Command="{Binding OpenLocationCommand}" ToolTip="{Binding OpenLocationTooltip}"/>
                                    <Button Content="Open frames" Style="{StaticResource SecondaryButton}"
                                            MinHeight="0" Padding="14,8" FontSize="12.5" Margin="8,0,0,0"
                                            Command="{Binding OpenFramesCommand}" ToolTip="Open the generated frames folder"/>
                                    <Button Content="Export frames…" Style="{StaticResource SecondaryButton}"
                                            MinHeight="0" Padding="14,8" FontSize="12.5" Margin="8,0,0,0"
                                            Command="{Binding ExportFramesCommand}"
                                            ToolTip="Copy the frame PNGs to a folder you choose, with per-frame checksums"/>
                                    <Button Content="Delete" Style="{StaticResource DangerGhostButton}"
                                            Margin="8,0,0,0" Command="{Binding DeleteCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="0" Grid.RowSpan="2" Background="#99000000"
                Visibility="{Binding IsExportPromptOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Padding="28" MaxWidth="440" Margin="32"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding ExportPromptTitle}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="The frame PNGs are copied into a subfolder you choose, alongside a manifest with a per-frame checksum."
                               Style="{StaticResource SubtleText}" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <CheckBox Content="Compress to a single .7z (maximum compression)"
                              IsChecked="{Binding CompressExport}" Margin="0,18,0,0" FontSize="13"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                MinWidth="96" Command="{Binding CancelExportCommand}"/>
                        <Button Content="Export" Style="{StaticResource PrimaryButton}"
                                MinWidth="112" Margin="10,0,0,0" Command="{Binding ConfirmExportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
