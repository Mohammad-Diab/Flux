<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
           xmlns:vm="clr-namespace:FluxCast.ViewModels"
             x:Class="FluxCast.Views.NewStreamPage"
      x:DataType="vm:NewStreamViewModel"
          Title="New Stream Configuration"
     BackgroundColor="{StaticResource Primary}">

    <ScrollView>
    <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="600">

      <!-- Header -->
 <Label Text="Configure New Encoding Stream" 
             FontSize="24" 
         FontAttributes="Bold"
      HorizontalOptions="Center"
         TextColor="White"/>

        <BoxView HeightRequest="2" Color="White" Opacity="0.3"/>

  <!-- Input Selection -->
        <Frame BackgroundColor="White" CornerRadius="10" Padding="20">
    <VerticalStackLayout Spacing="15">
 <Label Text="1. Select Input" FontSize="18" FontAttributes="Bold"/>
    
      <Button x:Name="SelectInputButton"
              Text="Select Input"
   Clicked="OnSelectInputClicked"
      BackgroundColor="#512BD4"
           TextColor="White"
         HorizontalOptions="Fill"/>

        <Label Text="{Binding SelectedPath, StringFormat='Selected: {0}'}" 
       FontSize="12" 
     TextColor="Gray"
         IsVisible="{Binding SelectedPath, Converter={StaticResource IsNotNullConverter}}"/>
  
           <Label Text="{Binding InputType, StringFormat='Type: {0}'}" 
       FontSize="11" 
     TextColor="#512BD4"
              FontAttributes="Bold"
              IsVisible="{Binding SelectedPath, Converter={StaticResource IsNotNullConverter}}"/>
  </VerticalStackLayout>
      </Frame>

     <!-- Encoding Settings -->
  <Frame BackgroundColor="White" CornerRadius="10" Padding="20">
        <VerticalStackLayout Spacing="15">
        <Label Text="2. Encoding Settings" FontSize="18" FontAttributes="Bold"/>

     <!-- Tile Size -->
       <Grid ColumnDefinitions="Auto,*" RowSpacing="5">
      <Label Grid.Column="0" Text="Tile Size:" VerticalOptions="Center"/>
     <Picker Grid.Column="1" 
 x:Name="TileSizePicker"
             SelectedIndex="3"
      Title="Select tile size">
      <Picker.ItemsSource>
 <x:Array Type="{x:Type x:String}">
      <x:String>2x2 px</x:String>
  <x:String>4x4 px</x:String>
       <x:String>6x6 px</x:String>
      <x:String>8x8 px</x:String>
  </x:Array>
  </Picker.ItemsSource>
       </Picker>
  </Grid>

          <!-- ECC Level -->
         <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
        <Label Grid.Column="0" Text="ECC Level:" VerticalOptions="Center"/>
   <Slider Grid.Column="1" 
     Minimum="1" 
   Maximum="8" 
  Value="{Binding EccLevel}"
             MinimumTrackColor="#512BD4"
     MaximumTrackColor="#E0E0E0"/>
         <Label Grid.Column="2" 
       Text="{Binding EccLevel, StringFormat='{0:F0}'}" 
   VerticalOptions="Center"
 WidthRequest="30"/>
        </Grid>

  <!-- Compression -->
     <HorizontalStackLayout Spacing="10">
    <CheckBox IsChecked="{Binding EnableCompression}" 
            IsEnabled="{Binding CanConfigureCompression}"/>
              <Label Text="Enable Compression (7z)" VerticalOptions="Center"/>
    </HorizontalStackLayout>
     </VerticalStackLayout>
         </Frame>

      <!-- Output Settings -->
      <Frame BackgroundColor="White" CornerRadius="10" Padding="20">
      <VerticalStackLayout Spacing="15">
      <Label Text="3. Output Settings" FontSize="18" FontAttributes="Bold"/>

   <!-- Export Directly -->
        <HorizontalStackLayout Spacing="10">
         <CheckBox IsChecked="{Binding ExportDirectly}"/>
            <Label Text="Export frames directly to folder" VerticalOptions="Center"/>
       </HorizontalStackLayout>

        <!-- Destination Folder -->
             <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
               <Entry Grid.Column="0" 
       Text="{Binding DestinationFolder}" 
    Placeholder="Destination folder (temporary if not exporting)"
          IsReadOnly="True"/>
         <Button Grid.Column="1" 
     Text="Browse..." 
     Clicked="OnBrowseDestinationClicked"/>
             </Grid>

    <Label Text="Tip: If 'Export directly' is unchecked, frames are stored temporarily for preview" 
   FontSize="11" 
      TextColor="Gray"
          FontAttributes="Italic"/>
        </VerticalStackLayout>
   </Frame>

          <!-- Playback Settings -->
  <Frame BackgroundColor="White" CornerRadius="10" Padding="20">
      <VerticalStackLayout Spacing="15">
          <Label Text="4. Playback Settings" FontSize="18" FontAttributes="Bold"/>

      <!-- Auto Play -->
    <HorizontalStackLayout Spacing="10">
<CheckBox IsChecked="{Binding AutoPlay}"/>
    <Label Text="Enable automatic playback" VerticalOptions="Center"/>
</HorizontalStackLayout>

      <!-- Frame Period -->
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
           <Label Grid.Column="0" Text="Frame Period:" VerticalOptions="Center" 
      IsEnabled="{Binding AutoPlay}"/>
               <Slider Grid.Column="1" 
    Minimum="0.1" 
     Maximum="10" 
    Value="{Binding FramePeriod}"
 IsEnabled="{Binding AutoPlay}"
                    MinimumTrackColor="#512BD4"
           MaximumTrackColor="#E0E0E0"/>
          <Label Grid.Column="2" 
        Text="{Binding FramePeriod, StringFormat='{0:F1}s'}" 
        VerticalOptions="Center"
           IsEnabled="{Binding AutoPlay}"
       WidthRequest="50"/>
         </Grid>
         </VerticalStackLayout>
        </Frame>

      <!-- Action Buttons -->
 <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
           <Button Grid.Column="0" 
    Text="Cancel" 
              Clicked="OnCancelClicked"
BackgroundColor="#757575"
         TextColor="White"/>
              <Button Grid.Column="1" 
         Text="Start Encoding" 
            Clicked="OnStartEncodingClicked"
     BackgroundColor="#512BD4"
       TextColor="White"/>
   </Grid>
        </VerticalStackLayout>
  </ScrollView>
</ContentPage>
