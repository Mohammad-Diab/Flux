<UserControl x:Class="FluxCast.Views.EncodeSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="640" Margin="32" VerticalAlignment="Center">
        <StackPanel>
            <TextBlock Text="FluxCast" Style="{StaticResource HeadingText}" FontSize="32"/>
            <TextBlock Text="Turn a file or folder into frames for optical transfer."
                       Style="{StaticResource SubtleText}" FontSize="14" Margin="0,4,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SelectedPath, Mode=OneWay}" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="File…" Command="{Binding PickFileCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                <Button Grid.Column="2" Content="Folder…" Command="{Binding PickFolderCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
            </Grid>

            <TextBlock Text="{Binding SourceSummary}" Margin="2,8,0,0" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SourceInfo.IsValid}" Value="False">
                                <Setter Property="Foreground" Value="#C62828"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="Measuring…" Foreground="Gray" FontSize="13" Margin="2,4,0,0"
                       Visibility="{Binding IsValidating, Converter={StaticResource BoolToVisibility}}"/>

            <Border Style="{StaticResource Card}" Padding="12,10" Margin="0,10,0,0"
                    Visibility="{Binding SourceDetails, Converter={StaticResource NullToCollapsed}}">
                <StackPanel>
                    <TextBlock Text="{Binding SourceDetails}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding EstimatedFrames}" FontSize="12" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Error correction" Style="{StaticResource SubtleText}" Margin="0,24,0,4"/>
            <ComboBox ItemsSource="{Binding EccLevels}" SelectedItem="{Binding SelectedEccLevel}"/>

            <CheckBox Content="Compress with 7-Zip (folders are always compressed)"
                      IsChecked="{Binding Compress}" Margin="2,16,0,0" FontSize="13">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompressLocked}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </CheckBox.Style>
            </CheckBox>

            <Button Content="Start encoding" Command="{Binding StartCommand}"
                    Style="{StaticResource PrimaryButton}" FontSize="16" Padding="0,12" Margin="0,32,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
