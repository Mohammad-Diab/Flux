<UserControl x:Class="FluxCast.Views.EncodeSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="620" Margin="32" VerticalAlignment="Center">
        <StackPanel>
            <TextBlock Text="FluxCast" Style="{StaticResource BrandTitle}"/>
            <TextBlock Text="Turn a file or folder into frames for optical transfer."
                       Style="{StaticResource SubtleText}" FontSize="14" Margin="0,6,0,20"
                       HorizontalAlignment="Center" TextAlignment="Center"/>

            <Border Style="{StaticResource Card}" Padding="28">
                <StackPanel>
                    <TextBlock Text="SOURCE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" AllowDrop="True" Background="Transparent"
                              DragOver="OnSourceDragOver" Drop="OnSourceDrop">
                            <TextBox Text="{Binding SelectedPath, Mode=OneWay}" IsReadOnly="True" AllowDrop="False"/>
                            <TextBlock Text="Drop a file or folder here" IsHitTestVisible="False"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Margin="14,0,0,0" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="File…" Command="{Binding PickFileCommand}"
                                Style="{StaticResource SecondaryButton}" MinWidth="104" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Content="Folder…" Command="{Binding PickFolderCommand}"
                                Style="{StaticResource SecondaryButton}" MinWidth="104" Margin="8,0,0,0"/>
                    </Grid>

                    <TextBlock Text="{Binding SourceSummary}" Margin="2,8,0,0" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SourceInfo.IsValid}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Measuring…" Foreground="Gray" FontSize="13" Margin="2,4,0,0"
                               Visibility="{Binding IsValidating, Converter={StaticResource BoolToVisibility}}"/>

                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,10,0,0"
                            Visibility="{Binding SourceDetails, Converter={StaticResource NullToCollapsed}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SourceDetails}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding EstimatedFrames}" FontSize="12" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="ERROR CORRECTION" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="2,24,0,10"/>
                    <ComboBox ItemsSource="{Binding EccLevels}" SelectedItem="{Binding SelectedEccLevel}"/>

                    <TextBlock Text="TRANSFER SPEED" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="2,24,0,10"/>
                    <ComboBox ItemsSource="{Binding TileSizes}" SelectedItem="{Binding SelectedTileSize}"/>
                    <ComboBox ItemsSource="{Binding Colors}" SelectedItem="{Binding SelectedColor}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding GridSummary}" FontSize="12" Foreground="{StaticResource AccentBrush}"
                               Margin="2,8,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding GridCaution}" FontSize="12" Foreground="{StaticResource DangerBrush}"
                               Margin="2,4,0,0" TextWrapping="Wrap"
                               Visibility="{Binding GridCaution, Converter={StaticResource NullToCollapsed}}"/>

                    <CheckBox Content="Compress with 7-Zip (folders are always compressed)"
                              IsChecked="{Binding Compress}" Margin="2,16,0,0" FontSize="13">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompressLocked}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <Button Content="Start encoding" Command="{Binding StartCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Margin="0,24,0,0"/>
                    <Button Content="Test frame on this channel" Command="{Binding TestFrameCommand}"
                            Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0"
                            ToolTip="Render one frame at these settings to capture in FluxRead before a full transfer"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
