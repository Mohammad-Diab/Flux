<UserControl x:Class="FluxCast.Views.EncodeSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MaxWidth="640" Margin="32" VerticalAlignment="Center">
        <StackPanel>
            <TextBlock Text="FluxCast" FontSize="34" FontWeight="Light"/>
            <TextBlock Text="Turn a file or folder into frames for optical transfer."
                       FontSize="14" Foreground="Gray" Margin="0,4,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SelectedPath, Mode=OneWay}" IsReadOnly="True"
                         VerticalContentAlignment="Center" Padding="8,6" FontSize="13"/>
                <Button Grid.Column="1" Content="File…" Command="{Binding PickFileCommand}"
                        Padding="16,6" Margin="8,0,0,0"/>
                <Button Grid.Column="2" Content="Folder…" Command="{Binding PickFolderCommand}"
                        Padding="16,6" Margin="8,0,0,0"/>
            </Grid>

            <TextBlock Text="{Binding SourceSummary}" Margin="2,8,0,0" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SourceInfo.IsValid}" Value="False">
                                <Setter Property="Foreground" Value="#C62828"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="Measuring…" Foreground="Gray" FontSize="13" Margin="2,4,0,0"
                       Visibility="{Binding IsValidating, Converter={StaticResource BoolToVisibility}}"/>

            <Border Background="#FFF3F3F3" CornerRadius="4" Padding="12,8" Margin="0,10,0,0"
                    Visibility="{Binding SourceDetails, Converter={StaticResource NullToCollapsed}}">
                <StackPanel>
                    <TextBlock Text="{Binding SourceDetails}" FontSize="12" Foreground="#FF404040" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding EstimatedFrames}" FontSize="12" Foreground="#FF1976D2" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Error correction" FontSize="13" Foreground="Gray" Margin="0,24,0,4"/>
            <ComboBox ItemsSource="{Binding EccLevels}" SelectedItem="{Binding SelectedEccLevel}"
                      Padding="8,6" FontSize="13"/>

            <CheckBox Content="Compress with 7-Zip (folders are always compressed)"
                      IsChecked="{Binding Compress}" Margin="2,16,0,0" FontSize="13">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompressLocked}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </CheckBox.Style>
            </CheckBox>

            <Button Content="Start encoding" Command="{Binding StartCommand}"
                    FontSize="16" Padding="0,12" Margin="0,32,0,0"
                    Background="#1976D2" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</UserControl>
