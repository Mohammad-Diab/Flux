<UserControl x:Class="FluxCast.Views.AmbientBackground"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid>
        <Ellipse Width="760" Height="760" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-280,-320,0,0" Opacity="0.16">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3B82F6" Offset="0"/>
                    <GradientStop Color="#003B82F6" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Orb1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="680" Height="680" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-260,-300" Opacity="0.14">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#C13BFF" Offset="0"/>
                    <GradientStop Color="#00C13BFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Orb2"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="520" Height="520" HorizontalAlignment="Center" VerticalAlignment="Center"
                 Margin="120,180,0,0" Opacity="0.10">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C5CFF" Offset="0"/>
                    <GradientStop Color="#007C5CFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Orb3"/>
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="Orb1" Storyboard.TargetProperty="X"
                                     From="0" To="220" Duration="0:0:34">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb1" Storyboard.TargetProperty="Y"
                                     From="0" To="120" Duration="0:0:27">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2" Storyboard.TargetProperty="X"
                                     From="0" To="-240" Duration="0:0:40">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2" Storyboard.TargetProperty="Y"
                                     From="0" To="-140" Duration="0:0:31">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb3" Storyboard.TargetProperty="X"
                                     From="-160" To="160" Duration="0:0:45">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
