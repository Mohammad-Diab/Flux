<UserControl x:Class="FluxCast.Views.PresenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Right" Command="{Binding NextCommand}"/>
        <KeyBinding Key="Left" Command="{Binding BackCommand}"/>
    </UserControl.InputBindings>
    <DockPanel Background="#FF262A30">
        <Border DockPanel.Dock="Bottom" Height="94" Background="#FF16181D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="1" Text="Keep this window still during transfer" FontSize="10.5"
                           Foreground="#FF8A9199" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <DockPanel Grid.Row="0" Margin="14,0">
                    <Button Content="❎  End session" Command="{Binding CloseCommand}" Focusable="False"
                            DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0" MinHeight="44"
                            Style="{StaticResource DangerGhostButton}"/>
                    <Border DockPanel.Dock="Right" Width="120"/>

                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="⏮  First" Command="{Binding FirstCommand}" Focusable="False"
                                Style="{StaticResource SecondaryButton}" MinHeight="44"/>
                        <Button Content="◀  Back" Command="{Binding BackCommand}" Focusable="False" Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}" FontSize="16" MinWidth="88" MinHeight="44"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Frame" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding GotoText, UpdateSourceTrigger=PropertyChanged}" Width="58" Height="44"
                                 Padding="4,0" TextAlignment="Center" VerticalContentAlignment="Center" ToolTip="Go to frame number">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding GotoCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock Text="{Binding TotalFrames, StringFormat=of {0}}" FontSize="16" Foreground="White"
                                   VerticalAlignment="Center" Margin="8,0,10,0"/>
                        <Button Content="Go" Command="{Binding GotoCommand}" Focusable="False"
                                Style="{StaticResource SecondaryButton}" MinHeight="44"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Next  ▶" Command="{Binding NextCommand}" Focusable="False"
                                Style="{StaticResource PrimaryButton}" FontSize="16" MinWidth="88" MinHeight="44"/>
                        <Button Content="Last  ⏭" Command="{Binding LastCommand}" Focusable="False" Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}" MinHeight="44"/>
                    </StackPanel>
                    </Grid>
                </DockPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid x:Name="FrameArea" Margin="10">
                <Image x:Name="FrameImage" Source="{Binding CurrentFrame}"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       SnapsToDevicePixels="True" UseLayoutRounding="True"
                       Stretch="Uniform"/>
            </Grid>
            <Border x:Name="SizeWarning" Background="#CCB91C1C" VerticalAlignment="Top" HorizontalAlignment="Center"
                    CornerRadius="0,0,6,6" Padding="14,7" Visibility="Collapsed">
                <TextBlock Text="Window is small — enlarge it so the tiles stay large enough to decode reliably."
                           Foreground="White" FontSize="12.5"/>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
