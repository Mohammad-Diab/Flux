<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FluxCast.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FluxCast"
    xmlns:views="clr-namespace:FluxCast.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="FluxCast">

    <Shell.MenuBarItems>
        <MenuBarItem Text="File">
  <MenuFlyoutItem Text="New Stream..." 
     Clicked="OnNewStreamClicked"/>
    <MenuFlyoutSeparator/>
<MenuFlyoutItem Text="Resume Stream..." 
     Clicked="OnResumeStreamClicked"/>
 <MenuFlyoutSeparator/>
   <MenuFlyoutItem Text="Exit" 
     Clicked="OnExitClicked"/>
        </MenuBarItem>
     
        <MenuBarItem Text="Help">
      <MenuFlyoutItem Text="About FluxCast..." 
   Clicked="OnAboutClicked"/>
 <MenuFlyoutItem Text="Documentation" 
           Clicked="OnDocumentationClicked"/>
     </MenuBarItem>
    </Shell.MenuBarItems>

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
