<Window x:Class="FluxCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FluxCast.ViewModels"
        xmlns:views="clr-namespace:FluxCast.Views"
        Title="FluxCast"
        Width="1040" Height="740"
        MinWidth="880" MinHeight="640"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:EncodeSetupViewModel}">
            <views:EncodeSetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EncodeProgressViewModel}">
            <views:EncodeProgressView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PresenterViewModel}">
            <views:PresenterView/>
        </DataTemplate>
    </Window.Resources>
    <DockPanel>
        <views:TitleBar DockPanel.Dock="Top" Title="FluxCast" Subtitle="Optical sender"/>
        <ContentControl Content="{Binding Current}"/>
    </DockPanel>
</Window>
