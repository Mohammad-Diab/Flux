<Window x:Class="FluxCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FluxCast.ViewModels"
        xmlns:views="clr-namespace:FluxCast.Views"
        Title="FluxCast"
        Width="1000" Height="700"
        MinWidth="860" MinHeight="620"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:EncodeSetupViewModel}">
            <views:EncodeSetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EncodeProgressViewModel}">
            <views:EncodeProgressView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PresenterViewModel}">
            <views:PresenterView/>
        </DataTemplate>
    </Window.Resources>
    <ContentControl Content="{Binding Current}"/>
</Window>
