<Window x:Class="FluxCast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FluxCast.ViewModels"
        xmlns:views="clr-namespace:FluxCast.Views"
        xmlns:controls="clr-namespace:Flux.Ui.Controls;assembly=Flux.Ui"
        xmlns:ui="clr-namespace:Flux.Ui.Views;assembly=Flux.Ui"
        xmlns:uivm="clr-namespace:Flux.Ui.ViewModels;assembly=Flux.Ui"
        Title="FluxCast"
        Icon="/Assets/AppIcon.ico"
        Width="1040" Height="740"
        MinWidth="880" MinHeight="640"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:EncodeSetupViewModel}">
            <views:EncodeSetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EncodeProgressViewModel}">
            <views:EncodeProgressView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PresenterViewModel}">
            <views:PresenterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecentCastsViewModel}">
            <views:RecentCastsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type uivm:SettingsViewModel}">
            <ui:SettingsView/>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <ui:AmbientBackground/>
        <DockPanel x:Name="RootContent">
            <ui:TitleBar DockPanel.Dock="Top" Title="FluxCast" Subtitle="Optical sender"
                         BrandGeometry="M7,1 L13,7 L9.5,7 L9.5,13 L4.5,13 L4.5,7 L1,7 Z"
                         ShowSettingsButton="{Binding CanOpenSettings}" SettingsCommand="{Binding ShowSettingsCommand}"
                         ShowBackButton="{Binding IsSettingsOpen}" BackCommand="{Binding CloseSettingsCommand}"/>
            <Border DockPanel.Dock="Top" Padding="24,8,24,2"
                    Visibility="{Binding ShowTabs, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Cast" GroupName="Tab" Style="{StaticResource TabRadio}"
                                 IsChecked="{Binding IsHistoryTab, Converter={StaticResource InverseBool}, Mode=TwoWay}"/>
                    <RadioButton Content="History" GroupName="Tab" Style="{StaticResource TabRadio}"
                                 IsChecked="{Binding IsHistoryTab, Mode=TwoWay}"/>
                </StackPanel>
            </Border>
            <controls:TransitionHost Content="{Binding Current}"
                                     HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </DockPanel>
    </Grid>
</Window>
