<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          xmlns:vm="clr-namespace:FluxCast.ViewModels"
 x:Class="FluxCast.MainPage"
          x:DataType="vm:MainViewModel"
Title="FluxCast">

<Grid RowDefinitions="*,Auto">
     
        <!-- Frame Preview Area -->
 <Border Grid.Row="0" 
         Stroke="#512BD4" 
    StrokeThickness="2"
Margin="20"
   BackgroundColor="White">
     <Grid>
   <!-- Empty State -->
<VerticalStackLayout HorizontalOptions="Center" 
          VerticalOptions="Center"
  Spacing="20"
    IsVisible="{Binding HasStream, Converter={StaticResource InvertedBoolConverter}}">
       <Label Text="[Frame]" FontSize="72" FontFamily="Segoe UI Symbol"/>
    <Label Text="No Stream Loaded" 
        FontSize="24" 
          FontAttributes="Bold"
            TextColor="Gray"/>
 <Label Text="Use File - New Stream to begin encoding" 
        FontSize="14"
       TextColor="Gray"/>
              </VerticalStackLayout>

    <!-- Encoding Progress -->
        <VerticalStackLayout HorizontalOptions="Center" 
           VerticalOptions="Center"
 Spacing="20"
     IsVisible="{Binding IsEncoding}">
     <ActivityIndicator IsRunning="{Binding IsEncoding}" 
            Color="#512BD4"
  WidthRequest="50"
  HeightRequest="50"/>
   <Label Text="{Binding StatusMessage}" 
      FontSize="16" 
   TextColor="Gray"/>
<ProgressBar Progress="{Binding EncodingProgress}" 
ProgressColor="#512BD4"
         WidthRequest="300"/>
   <Label Text="{Binding EncodingProgress, StringFormat='{0:P0}'}" 
       TextColor="Gray"/>
      </VerticalStackLayout>

    <!-- Frame Display -->
   <Image Source="{Binding CurrentFrameImage, Converter={StaticResource ByteArrayToImageSourceConverter}}"
       Aspect="AspectFit"
       IsVisible="{Binding HasStream}"/>
    </Grid>
        </Border>

        <!-- Bottom Controls -->
   <Grid Grid.Row="1" 
      Padding="20,10"
     RowDefinitions="Auto,Auto"
   RowSpacing="10"
          BackgroundColor="#F5F5F5">
      
<!-- Navigation Controls -->
    <Grid Grid.Row="0" 
     ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" 
 ColumnSpacing="10"
   IsVisible="{Binding HasStream}">
  <Button Grid.Column="0" 
     Text="Previous" 
    Command="{Binding PreviousFrameCommand}"
 WidthRequest="100"/>
      
         <StackLayout Grid.Column="1" 
  VerticalOptions="Center"
     Orientation="Horizontal"
      Spacing="5">
    <Label Text="{Binding CurrentFrameIndex, StringFormat='Frame {0}'}"
        VerticalOptions="Center"
       FontAttributes="Bold"/>
     <Label Text="/" VerticalOptions="Center"/>
    <Label Text="{Binding TotalFrames}"
   VerticalOptions="Center"
    FontAttributes="Bold"/>
    </StackLayout>

        <!-- Jump to Frame -->
        <Label Grid.Column="2" 
   Text="Jump to:" 
       VerticalOptions="Center"
         Margin="10,0,0,0"/>
   
        <Entry Grid.Column="3" 
   x:Name="JumpFrameEntry"
     Placeholder="Frame #" 
     Keyboard="Numeric"
  WidthRequest="80"
            VerticalOptions="Center"
      HorizontalOptions="Start"/>
        
  <Button Grid.Column="4" 
  Text="Go" 
        Command="{Binding JumpToFrameCommand}"
            CommandParameter="{Binding Source={x:Reference JumpFrameEntry}, Path=Text}"
  WidthRequest="60"/>
    <Button Grid.Column="5" 
       Text="{Binding IsPlaying, Converter={StaticResource PlayPauseConverter}}" 
   Command="{Binding TogglePlaybackCommand}"
          WidthRequest="100"/>
   
  <Button Grid.Column="6" 
      Text="Next" 
      Command="{Binding NextFrameCommand}"
    WidthRequest="100"/>
     </Grid>

    <!-- Export Button Row -->
  <Grid Grid.Row="1" 
          ColumnDefinitions="*,Auto" 
      ColumnSpacing="10"
   IsVisible="{Binding HasStream}">
        
        <Label Grid.Column="0" 
        Text="{Binding StatusMessage}"
  FontSize="12"
 TextColor="Gray"
   FontAttributes="Italic"
  VerticalOptions="Center"/>
    
 <Button Grid.Column="1" 
         Text="Export" 
    Command="{Binding ExportFramesCommand}"
                BackgroundColor="#28a745"
        TextColor="White"
             WidthRequest="100"/>
    </Grid>

  <!-- Status Bar (when no stream) -->
   <Label Grid.Row="1" 
      Text="{Binding StatusMessage}"
      FontSize="12"
      TextColor="Gray"
  FontAttributes="Italic"
  HorizontalOptions="Start"
   IsVisible="{Binding HasStream, Converter={StaticResource InvertedBoolConverter}}"/>
  </Grid>
    </Grid>

</ContentPage>
