<Window x:Class="FluxRead.Views.StallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRead — Transfer stalled"
        Icon="/Assets/AppIcon.ico"
        SizeToContent="Height" Width="440" ResizeMode="NoResize"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterOwner">
    <StackPanel x:Name="RootContent" Margin="24">
        <TextBlock Text="No new frames arriving" Style="{StaticResource HeadingText}"/>
        <TextBlock x:Name="DetailText" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0"/>

        <Button Content="Retry" HorizontalAlignment="Stretch" Margin="0,20,0,0"
                Style="{StaticResource PrimaryButton}" Click="OnRetry"/>
        <TextBlock Text="Click again and keep going — for a brief hiccup." Style="{StaticResource SubtleText}"
                   FontSize="11" Margin="2,4,0,0"/>

        <Button Content="Recalibrate Next" HorizontalAlignment="Stretch" Margin="0,14,0,0"
                Style="{StaticResource SecondaryButton}" Click="OnRecalibrateNext"/>
        <TextBlock Text="Re-find the Next button (its click point may be off)." Style="{StaticResource SubtleText}"
                   FontSize="11" Margin="2,4,0,0"/>

        <Button Content="Adjust region" HorizontalAlignment="Stretch" Margin="0,14,0,0"
                Style="{StaticResource SecondaryButton}" Click="OnAdjustRegion"/>
        <TextBlock Text="Re-detect the frame area (if the sender window moved)." Style="{StaticResource SubtleText}"
                   FontSize="11" Margin="2,4,0,0"/>

        <Button Content="Cancel transfer" HorizontalAlignment="Stretch" Margin="0,18,0,0"
                Style="{StaticResource DangerGhostButton}" Click="OnCancel"/>
    </StackPanel>
</Window>
