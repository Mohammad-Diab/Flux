<UserControl x:Class="FluxRead.Views.LiveCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FluxRead.Controls">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Live optical capture" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Select the on-screen region, teach the Next button, then start the transfer."
                       Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ Left: control panel ============ -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Setup steps (scrolls if the live previews make it taller than the card) -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="SETUP" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0,0,10"/>

                        <Button Content="1 · Select region…" HorizontalAlignment="Stretch"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnSelectRegion" IsEnabled="{Binding CanConfigure}"/>
                        <TextBlock Text="{Binding RegionText}" Style="{StaticResource SubtleText}"
                                   FontSize="12" Margin="2,6,0,0"/>
                        <!-- Region preview sits directly under its own step -->
                        <TextBlock Text="Region preview (live)" Style="{StaticResource SubtleText}" Margin="0,10,0,0"
                                   Visibility="{Binding RegionPreview, Converter={StaticResource NullToCollapsed}}"/>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="6" Margin="0,6,0,0"
                                Visibility="{Binding RegionPreview, Converter={StaticResource NullToCollapsed}}">
                            <Image Source="{Binding RegionPreview}" MaxHeight="140" Stretch="Uniform"/>
                        </Border>

                        <Button Content="2 · Calibrate Next (F8)…" HorizontalAlignment="Stretch" Margin="0,18,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnCalibrate" IsEnabled="{Binding CanConfigure}"/>
                        <TextBlock Text="{Binding CalibrationText}" Style="{StaticResource SubtleText}"
                                   FontSize="12" Margin="2,6,0,0"/>
                        <!-- Next-button preview sits directly under its own step -->
                        <TextBlock Text="Next button" Style="{StaticResource SubtleText}" Margin="0,10,0,0"
                                   Visibility="{Binding CalibrationPreview, Converter={StaticResource NullToCollapsed}}"/>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="6" Margin="0,6,0,0"
                                Visibility="{Binding CalibrationPreview, Converter={StaticResource NullToCollapsed}}">
                            <Image Source="{Binding CalibrationPreview}" MaxHeight="70" Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                    </ScrollViewer>

                    <!-- Status (docked above the CTA) -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="0,14,0,0" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding StateText}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProgressText}" Style="{StaticResource SubtleText}"
                                       FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="2" Content="Start transfer" HorizontalAlignment="Stretch" Margin="0,16,0,0"
                            Style="{StaticResource PrimaryButton}" Click="OnStart" IsEnabled="{Binding CanStart}"/>
                </Grid>
            </Border>

            <!-- ============ Right: activity log ============ -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0" Padding="6">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360" Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Log.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Activity log" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Style="{StaticResource SubtleText}" TextAlignment="Center" Margin="0,8,0,0"
                                   Text="Once you select a region, calibrate the Next button, and press Start, each decoded frame, re-click, stall, and the final result will appear here."/>
                    </StackPanel>
                    <ListBox x:Name="LogList" ItemsSource="{Binding Log}" FontFamily="Consolas" FontSize="11" BorderThickness="0"
                             Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
