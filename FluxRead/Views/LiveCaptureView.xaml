<UserControl x:Class="FluxRead.Views.LiveCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FluxRead.Controls">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Live optical capture" Style="{StaticResource HeadingText}"
                   controls:Motion.RiseDelay="0"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Grid controls:Motion.RiseDelay="70">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="1 · Select region…" MinWidth="180" Style="{StaticResource SecondaryButton}"
                        Click="OnSelectRegion" IsEnabled="{Binding CanConfigure}"/>
                <TextBlock Grid.Column="1" Text="{Binding RegionText}" VerticalAlignment="Center" Margin="14,0,0,0"
                           Style="{StaticResource SubtleText}"/>
            </Grid>
            <Grid Margin="0,10,0,0" controls:Motion.RiseDelay="140">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="2 · Calibrate Next (F8)…" MinWidth="180" Style="{StaticResource SecondaryButton}"
                        Click="OnCalibrate" IsEnabled="{Binding CanConfigure}"/>
                <TextBlock Grid.Column="1" Text="{Binding CalibrationText}" VerticalAlignment="Center" Margin="14,0,0,0"
                           Style="{StaticResource SubtleText}"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,18,0,0" controls:Motion.RiseDelay="210">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding StateText}" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource SubtleText}" Margin="0,4,0,10"/>

                <TextBlock Text="Region preview (live)" Style="{StaticResource SubtleText}"
                           Visibility="{Binding RegionPreview, Converter={StaticResource NullToCollapsed}}"/>
                <Border Style="{StaticResource Card}" Padding="6" Margin="0,4,0,0"
                        Visibility="{Binding RegionPreview, Converter={StaticResource NullToCollapsed}}">
                    <Image Source="{Binding RegionPreview}" MaxHeight="150" Stretch="Uniform"/>
                </Border>

                <TextBlock Text="Next button" Style="{StaticResource SubtleText}" Margin="0,10,0,0"
                           Visibility="{Binding CalibrationPreview, Converter={StaticResource NullToCollapsed}}"/>
                <Border Style="{StaticResource Card}" Padding="6" Margin="0,4,0,0"
                        Visibility="{Binding CalibrationPreview, Converter={StaticResource NullToCollapsed}}">
                    <Image Source="{Binding CalibrationPreview}" MaxHeight="80" Stretch="Uniform"/>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="16,0,0,0" Padding="4">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360" Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Log.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Activity log" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Style="{StaticResource SubtleText}" TextAlignment="Center" Margin="0,8,0,0"
                                   Text="Once you select a region, calibrate the Next button, and press Start, each decoded frame, re-click, stall, and the final result will appear here."/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Log}" FontFamily="Consolas" FontSize="11" BorderThickness="0"
                             Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"
                    controls:Motion.RiseDelay="280">
            <Button Content="Start transfer" MinWidth="160" Style="{StaticResource PrimaryButton}"
                    Click="OnStart" IsEnabled="{Binding CanStart}"/>
        </StackPanel>
    </Grid>
</UserControl>
