<Window x:Class="FluxRead.Views.ManualResumeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRead — Continue reception"
        Icon="/Assets/AppIcon.ico"
        SizeToContent="Height" Width="440" ResizeMode="NoResize"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterOwner">
    <StackPanel x:Name="RootContent" Margin="24">
        <TextBlock x:Name="TitleText" Style="{StaticResource HeadingText}"/>
        <TextBlock x:Name="DetailText" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0"/>

        <Button Content="Continue" HorizontalAlignment="Stretch" Margin="0,20,0,0"
                Style="{StaticResource PrimaryButton}" Click="OnContinue"/>
        <TextBlock Text="FluxRead captures the frame you've navigated to, then keeps going."
                   Style="{StaticResource SubtleText}" FontSize="11" Margin="2,4,0,0"/>

        <Button Content="Cancel transfer" HorizontalAlignment="Stretch" Margin="0,16,0,0"
                Style="{StaticResource DangerGhostButton}" Click="OnCancel"/>
    </StackPanel>
</Window>
