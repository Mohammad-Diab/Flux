<UserControl x:Class="FluxRead.Views.FolderDecodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Folder decode" Style="{StaticResource HeadingText}"/>
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FramesFolder, Mode=OneWay}" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="Pick frames folder…" Command="{Binding PickAndDecodeCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                        IsEnabled="{Binding IsDecoding, Converter={StaticResource InverseBool}}"/>
            </Grid>
        </StackPanel>

        <ProgressBar Grid.Row="1" Height="6" Margin="0,16,0,0" Minimum="0" Maximum="1"
                     Value="{Binding ProgressValue, Mode=OneWay}"
                     Visibility="{Binding IsDecoding, Converter={StaticResource BoolToVisibility}}"/>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="6">
        <DataGrid ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  FontSize="12" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Frame" Binding="{Binding FileName}" Width="160"/>
                <DataGridTextColumn Header="Id" Binding="{Binding FrameId}" Width="50"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Success}" Value="False">
                            <Setter Property="Background" Value="#33FF5C6C"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleText}"/>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0"
                           Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Save…" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}" MinWidth="130" Margin="16,0,0,0"/>
        </Grid>
    </Grid>
</UserControl>
