<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FluxRead.ViewModels"
             x:Class="FluxRead.Views.InputModePage"
             x:DataType="vm:InputModeViewModel"
             Title="Start Reading"
             BackgroundColor="{StaticResource Primary}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="600">

            <!-- Header -->
            <Label Text="Select Input Source"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White"/>

            <BoxView HeightRequest="2" Color="White" Opacity="0.3"/>

            <!-- Mode Selection -->
            <Frame BackgroundColor="White" CornerRadius="10" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <!-- Folder Mode -->
                    <RadioButton Content="From Folder (Batch Decode)"
                                 GroupName="InputMode"
                                 IsChecked="True"/>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding IsFolderMode}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Entry Grid.Column="0"
                                   Text="{Binding SelectedFolder}"
                                   Placeholder="Folder with frames..."
                                   IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Text="Browse..."
                                    Clicked="OnBrowseFolderClicked"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Entry Grid.Column="0"
                                   Text="{Binding OutputFolder}"
                                   Placeholder="Output folder..."
                                   IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Text="Browse..."
                                    Clicked="OnBrowseOutputClicked"/>
                        </Grid>

                        <Label Text="Note: Scans for frame_NNNNNN.png files and decodes them in order."
                               FontSize="11"
                               TextColor="Gray"
                               FontAttributes="Italic"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>

                    <!-- Screen Capture Mode -->
                    <RadioButton Content="From Screen (Live Capture)"
                                 GroupName="InputMode"
                                 IsChecked="False"/>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding IsScreenCaptureMode}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Frame Period:"
                                   VerticalOptions="Center"/>
                            <Slider Grid.Column="1"
                                    Minimum="0.1"
                                    Maximum="10"
                                    Value="{Binding FramePeriod}"
                                    MinimumTrackColor="#512BD4"
                                    MaximumTrackColor="#E0E0E0"/>
                            <Label Grid.Column="2"
                                   Text="{Binding FramePeriod, StringFormat='{0:F1}s'}"
                                   VerticalOptions="Center"
                                   WidthRequest="50"/>
                        </Grid>

                        <Label Text="Window will minimize and capture screen at specified interval."
                               FontSize="11"
                               TextColor="Gray"
                               FontAttributes="Italic"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="#757575"
                        TextColor="White"/>
                <Button Grid.Column="1"
                        Text="Start"
                        Clicked="OnStartClicked"
                        BackgroundColor="#512BD4"
                        TextColor="White"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
