<Window x:Class="FluxRead.Views.MiniCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Flux.Ui.Views;assembly=Flux.Ui"
        Title="FluxRead — Capturing"
        Icon="/Assets/AppIcon.ico"
        Width="400" Height="368" ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="True"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="Manual">
    <DockPanel>
        <!-- Caption-less popover header: brand mark + title, draggable (WindowChrome caption),
             no minimize/maximize/close — the transfer is controlled by Pause/Cancel below. -->
        <Border DockPanel.Dock="Top" Height="46" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <ui:BrandMark Width="20" Height="20"/>
                <TextBlock Text="FluxRead" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Capturing" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
        <Grid Margin="18,4,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding StateText}" FontSize="18" FontWeight="SemiBold"/>
            <StackPanel Grid.Row="1">
                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>
                <ProgressBar Height="6" Margin="0,8,0,0" Minimum="0" Maximum="1" Value="{Binding TransferProgress}"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource SubtleText}" FontSize="11"/>
                    <TextBlock Text="{Binding SpeedText}" Style="{StaticResource SubtleText}" FontSize="11" Margin="14,0,0,0"/>
                    <TextBlock Text="{Binding EtaText}" Style="{StaticResource SubtleText}" FontSize="11" Margin="14,0,0,0"/>
                </StackPanel>
                <ProgressBar Height="6" Margin="0,10,0,0" Minimum="0" Maximum="1" Value="{Binding DecompressProgress}"
                             Visibility="{Binding IsDecompressing, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Border Style="{StaticResource Card}" Padding="6">
                    <Image Source="{Binding LastThumbnail}" Stretch="Uniform"/>
                </Border>
                <!-- Shown when frames were skipped: which frames to re-show on the sender. -->
                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="12"
                        Visibility="{Binding IsRecovering, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Missing frames" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="On the sender, use Back or “go to frame” to re-show each frame below — FluxRead grabs them automatically."
                                   Style="{StaticResource SubtleText}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <TextBlock Text="{Binding MissingFramesText}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="PauseButton" Content="{Binding PauseLabel}" Style="{StaticResource SecondaryButton}"
                        MinWidth="96" Click="OnPauseToggle"/>
                <Button Content="Cancel" Style="{StaticResource DangerButton}" MinWidth="96" Margin="10,0,0,0"
                        Click="OnCancel"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
