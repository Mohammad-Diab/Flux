<Window x:Class="FluxRead.Views.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#33000000"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize" Cursor="Cross">
    <Canvas x:Name="RootCanvas">
        <Rectangle x:Name="SelectionRect" Stroke="#FF2EA0FF" StrokeThickness="2" Fill="#302EA0FF"
                   Visibility="Collapsed"/>
        <Border Canvas.Left="16" Canvas.Top="16" Background="#CC000000" CornerRadius="4" Padding="12,8">
            <TextBlock Foreground="White" FontSize="13"
                       Text="Drag a rectangle around the Client's frame area.  Enter/release to confirm · Esc to cancel"/>
        </Border>
        <TextBlock x:Name="SizeLabel" Foreground="White" FontSize="12" Background="#CC000000" Padding="4,2"
                   Visibility="Collapsed"/>
    </Canvas>
</Window>
