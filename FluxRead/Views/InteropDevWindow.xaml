<Window x:Class="FluxRead.Views.InteropDevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FluxRead.Views"
        Title="FluxRead — Interop Dev Tools"
        Icon="/Assets/AppIcon.ico"
        Width="760" Height="700"
        MinWidth="620" MinHeight="480"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <views:TitleBar DockPanel.Dock="Top" Title="FluxRead" Subtitle="Interop dev tools"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <StackPanel>
                <TextBlock Text="Interop dev tools" Style="{StaticResource HeadingText}" Margin="0,4,0,4"/>
                <TextBlock Text="Exercise each Win32 interop helper by hand." Style="{StaticResource SubtleText}"
                           Margin="0,0,0,18"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="DPI (PER-MONITOR)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <Button x:Name="DpiButton" Content="Read DPI scale under cursor (moves in 2s)"
                                HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" Click="OnReadDpi"/>
                        <TextBlock x:Name="DpiResult" Margin="2,10,0,0" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="SCREEN REGION CAPTURE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="CapX" Text="100" Width="64" Margin="0,0,12,0"/>
                            <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="CapY" Text="100" Width="64" Margin="0,0,12,0"/>
                            <TextBlock Text="W" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="CapW" Text="500" Width="64" Margin="0,0,12,0"/>
                            <TextBlock Text="H" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="CapH" Text="300" Width="64" Margin="0,0,12,0"/>
                            <Button Content="Capture" Style="{StaticResource SecondaryButton}" Click="OnCapture"/>
                        </StackPanel>
                        <TextBlock x:Name="CapResult" Margin="2,10,0,0" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,10,0,0" HorizontalAlignment="Left">
                            <Image x:Name="CapImage" MaxWidth="500" MaxHeight="300" Stretch="None"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="SYNTHESIZED CLICK" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="ClickX" Text="400" Width="72" Margin="0,0,12,0"/>
                            <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="ClickY" Text="400" Width="72" Margin="0,0,12,0"/>
                            <Button Content="Click there in 3s (cursor restored)"
                                    Style="{StaticResource SecondaryButton}" Click="OnClick"/>
                        </StackPanel>
                        <TextBlock x:Name="ClickResult" Margin="2,10,0,0" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="F8 HOTKEY (NEXT-BUTTON CALIBRATION)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <Button x:Name="HotkeyButton" Content="Arm F8" HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryButton}" Click="OnToggleHotkey"/>
                        <TextBlock x:Name="HotkeyResult" Margin="2,10,0,0" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Disarmed. Arm, then hover anywhere and press F8."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="WINDOW PLACEMENT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Move THIS window out of the region above (uses the capture X/Y/W/H)."
                                   Style="{StaticResource SubtleText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Ensure outside region" Style="{StaticResource SecondaryButton}" Click="OnEnsureOutside"/>
                            <Button Content="Toggle exclude-from-capture" Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Click="OnToggleExclude"/>
                        </StackPanel>
                        <TextBlock x:Name="PlacementResult" Margin="2,10,0,0" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
