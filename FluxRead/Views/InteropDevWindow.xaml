<Window x:Class="FluxRead.Views.InteropDevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRead — Interop Dev Tools"
        Width="720" Height="620"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <TextBlock Text="Interop dev tools" FontSize="20" FontWeight="Light" Margin="0,0,0,12"/>

            <GroupBox Header="DPI (per-monitor)" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <Button x:Name="DpiButton" Content="Read DPI scale under cursor (moves in 2s)" HorizontalAlignment="Left" Padding="10,4" Click="OnReadDpi"/>
                    <TextBlock x:Name="DpiResult" Margin="0,6,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Screen region capture" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="X" VerticalAlignment="Center"/>
                        <TextBox x:Name="CapX" Text="100" Width="60" Margin="4,0,10,0"/>
                        <TextBlock Text="Y" VerticalAlignment="Center"/>
                        <TextBox x:Name="CapY" Text="100" Width="60" Margin="4,0,10,0"/>
                        <TextBlock Text="W" VerticalAlignment="Center"/>
                        <TextBox x:Name="CapW" Text="500" Width="60" Margin="4,0,10,0"/>
                        <TextBlock Text="H" VerticalAlignment="Center"/>
                        <TextBox x:Name="CapH" Text="300" Width="60" Margin="4,0,10,0"/>
                        <Button Content="Capture" Padding="10,4" Click="OnCapture"/>
                    </StackPanel>
                    <TextBlock x:Name="CapResult" Margin="0,6,0,0" FontFamily="Consolas"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,6,0,0" HorizontalAlignment="Left">
                        <Image x:Name="CapImage" MaxWidth="500" MaxHeight="300" Stretch="None"/>
                    </Border>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Synthesized click" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="X" VerticalAlignment="Center"/>
                        <TextBox x:Name="ClickX" Text="400" Width="70" Margin="4,0,10,0"/>
                        <TextBlock Text="Y" VerticalAlignment="Center"/>
                        <TextBox x:Name="ClickY" Text="400" Width="70" Margin="4,0,10,0"/>
                        <Button Content="Click there in 3s (cursor restored)" Padding="10,4" Click="OnClick"/>
                    </StackPanel>
                    <TextBlock x:Name="ClickResult" Margin="0,6,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="F8 hotkey (Next-button calibration)" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <Button x:Name="HotkeyButton" Content="Arm F8" HorizontalAlignment="Left" Padding="10,4" Click="OnToggleHotkey"/>
                    <TextBlock x:Name="HotkeyResult" Margin="0,6,0,0" FontFamily="Consolas"
                               Text="Disarmed. Arm, then hover anywhere and press F8."/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Window placement" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Move THIS window out of the region above (uses the capture X/Y/W/H)."/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Ensure outside region" Padding="10,4" Click="OnEnsureOutside"/>
                        <Button Content="Toggle exclude-from-capture" Padding="10,4" Margin="8,0,0,0" Click="OnToggleExclude"/>
                    </StackPanel>
                    <TextBlock x:Name="PlacementResult" Margin="0,6,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</Window>
