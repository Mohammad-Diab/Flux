<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FluxRead.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FluxRead"
    Shell.FlyoutBehavior="Disabled"
    Title="FluxRead">

    <!-- Menu Bar -->
    <Shell.MenuBarItems>
        <MenuBarItem Text="File">
            <MenuFlyoutItem Text="Start Reading..."
                Clicked="OnStartReadingClicked"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Text="Resume Session..."
                Clicked="OnResumeSessionClicked"/>
            <MenuFlyoutSeparator/>
            <MenuFlyoutItem Text="Exit"
                Clicked="OnExitClicked"/>
        </MenuBarItem>
        <MenuBarItem Text="Help">
            <MenuFlyoutItem Text="About"
                Clicked="OnAboutClicked"/>
            <MenuFlyoutItem Text="Documentation"
                Clicked="OnDocumentationClicked"/>
        </MenuBarItem>
    </Shell.MenuBarItems>

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
