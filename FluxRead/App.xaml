<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FluxRead"
         xmlns:conv="clr-namespace:FluxRead.Converters"
 x:Class="FluxRead.App">
    <Application.Resources>
  <ResourceDictionary>
         <ResourceDictionary.MergedDictionaries>
             <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
        <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>
       
          <!-- Converters -->
      <conv:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
      <conv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
     </ResourceDictionary>
    </Application.Resources>
</Application>
