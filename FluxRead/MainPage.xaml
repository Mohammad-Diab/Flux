<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FluxRead.ViewModels"
             x:Class="FluxRead.MainPage"
             x:DataType="vm:MainViewModel"
             Title="FluxRead">

    <Grid RowDefinitions="*,200">

        <!-- Main Decode Area -->
        <Border Grid.Row="0"
                Stroke="#512BD4"
                StrokeThickness="2"
                Margin="20"
                BackgroundColor="White">
            <Grid>

                <!-- Empty State -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="20"
                                     IsVisible="{Binding HasSession, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="[Decoder]" FontSize="72" FontFamily="Segoe UI Symbol"/>
                    <Label Text="No Decoding Active"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="Gray"/>
                    <Label Text="Use File - Start Reading to begin decoding"
                           FontSize="14"
                           TextColor="Gray"/>
                </VerticalStackLayout>

                <!-- Decoding Progress -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="20"
                                     IsVisible="{Binding IsDecoding}">
                    <ActivityIndicator IsRunning="{Binding IsDecoding}"
                                       Color="#512BD4"
                                       WidthRequest="50"
                                       HeightRequest="50"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
                    <ProgressBar Progress="{Binding DecodingProgress}"
                                  ProgressColor="#512BD4"
                                  WidthRequest="300"/>
                    <Label Text="{Binding DecodingProgress, StringFormat='{0:P0}'}"
                           TextColor="Gray"/>
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="20"
                          HorizontalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="{Binding CurrentFrameIndex}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Current Frame"
                                   FontSize="11"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="{Binding TotalFrames}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Total Frames"
                                   FontSize="11"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="{Binding EccCorrections}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Orange"/>
                            <Label Text="ECC Corrections"
                                   FontSize="11"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="5">
                            <Label Text="{Binding CrcFailures}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Red"/>
                            <Label Text="CRC Failures"
                                   FontSize="11"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>

                <!-- Screen Capture Mode -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="20"
                                     IsVisible="{Binding IsCapturing}">
                    <Label Text="📷" FontSize="72"/>
                    <Label Text="Capturing Screenshots..."
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#512BD4"/>
                    <Label Text="{Binding StatusMessage}"
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding CurrentFrameIndex, StringFormat='Frame {0} captured'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#512BD4"/>
                    <Button Text="Stop Capture &amp; Decode"
                            Command="{Binding StopScreenCaptureCommand}"
                            BackgroundColor="#dc3545"
                            TextColor="White"
                            WidthRequest="200"/>
                    <Label Text="Press ESC or click Stop to finish capturing"
                           FontSize="12"
                           TextColor="Gray"
                           FontAttributes="Italic"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- Logs Panel -->
        <Border Grid.Row="1"
                Stroke="#512BD4"
                StrokeThickness="2"
                Margin="20,0,20,20"
                BackgroundColor="White">
            <Grid RowDefinitions="Auto,*,Auto">
                <Label Grid.Row="0"
                       Text="Logs"
                       FontSize="16"
                       FontAttributes="Bold"
                       Padding="10"
                       BackgroundColor="#F5F5F5"/>
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="10" Spacing="2">
                        <CollectionView ItemsSource="{Binding Logs}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}"
                                           FontSize="11"
                                           FontFamily="Consolas"
                                           TextColor="#333"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
                <Button Grid.Row="2"
                        Text="Export Logs"
                        Command="{Binding ExportLogsCommand}"
                        BackgroundColor="#512BD4"
                        TextColor="White"
                        Margin="10"
                        IsVisible="{Binding HasSession}"/>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
