<Window x:Class="FluxRead.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Flux.Ui.Views;assembly=Flux.Ui"
        xmlns:controls="clr-namespace:Flux.Ui.Controls;assembly=Flux.Ui"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="FluxRead"
        Icon="/Assets/AppIcon.ico"
        Width="1040" Height="720"
        MinWidth="760" MinHeight="540"
        Style="{StaticResource FluxWindow}"
        WindowStartupLocation="CenterScreen">
    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo ProgressState="{Binding State, Source={StaticResource TaskbarProgress}}"
                               ProgressValue="{Binding Value, Source={StaticResource TaskbarProgress}}"/>
    </Window.TaskbarItemInfo>
    <Grid>
        <views:AmbientBackground/>
        <DockPanel x:Name="RootContent">
            <views:TitleBar DockPanel.Dock="Top" Title="FluxRead" Subtitle="Optical receiver"/>
            <Border DockPanel.Dock="Top" Padding="24,8,24,2">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="LiveModeButton" Content="Live optical capture" GroupName="Mode"
                                 Style="{StaticResource TabRadio}" IsChecked="True" Checked="OnModeChanged"/>
                    <RadioButton x:Name="FolderModeButton" Content="Folder decode" GroupName="Mode"
                                 Style="{StaticResource TabRadio}" Checked="OnModeChanged"/>
                    <RadioButton x:Name="SettingsModeButton" Content="Settings" GroupName="Mode"
                                 Style="{StaticResource TabRadio}" Checked="OnModeChanged"/>
                </StackPanel>
            </Border>
            <controls:TransitionHost x:Name="ModeHost" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </DockPanel>
    </Grid>
</Window>
