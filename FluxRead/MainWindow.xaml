<Window x:Class="FluxRead.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRead"
        Width="960" Height="640"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFF3F3F3" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="FolderModeButton" Content="Folder decode" GroupName="Mode" IsChecked="True"
                             Margin="0,0,16,0" Checked="OnModeChanged"/>
                <RadioButton x:Name="LiveModeButton" Content="Live optical capture" GroupName="Mode"
                             Checked="OnModeChanged"/>
            </StackPanel>
        </Border>
        <ContentControl x:Name="ModeHost"/>
    </DockPanel>
</Window>
