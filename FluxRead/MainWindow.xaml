<Window x:Class="FluxRead.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FluxRead.ViewModels"
        xmlns:views="clr-namespace:FluxRead.Views"
        Title="FluxRead"
        Width="960" Height="640"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:FolderDecodeViewModel}">
            <views:FolderDecodeView/>
        </DataTemplate>
    </Window.Resources>
    <ContentControl Content="{Binding Current}"/>
</Window>
