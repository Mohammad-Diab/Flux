<UserControl x:Class="Flux.Ui.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <!-- Inset lives here (not on the Grid) so the ScrollViewer clips at the window edge,
                 leaving room for the cards' drop shadow instead of cropping it. -->
            <StackPanel MaxWidth="624" HorizontalAlignment="Left" Margin="24">
                <TextBlock Text="Settings" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="Appearance and performance." Style="{StaticResource SubtleText}" Margin="0,4,0,0"/>

                <Border Style="{StaticResource Card}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Use light, dark, or follow the Windows setting." Style="{StaticResource SubtleText}" Margin="0,2,0,14"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="System" GroupName="Theme" Style="{StaticResource TabRadio}" IsChecked="{Binding IsSystem, Mode=TwoWay}"/>
                            <RadioButton Content="Light" GroupName="Theme" Style="{StaticResource TabRadio}" IsChecked="{Binding IsLight, Mode=TwoWay}"/>
                            <RadioButton Content="Dark" GroupName="Theme" Style="{StaticResource TabRadio}" IsChecked="{Binding IsDark, Mode=TwoWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Motion" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Turn off animations for smoother performance on slower hardware. Animations also follow the Windows animation setting."
                                   Style="{StaticResource SubtleText}" Margin="0,2,0,14"/>
                        <CheckBox Content="Show animations" IsChecked="{Binding EnableAnimations, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                        Visibility="{Binding ShowDevTools, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Developer" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Low-level tools for exercising the capture, click, and DPI interop by hand."
                                   Style="{StaticResource SubtleText}" Margin="0,2,0,14"/>
                        <Button Content="Open dev tools…" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Command="{Binding OpenDevToolsCommand}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
