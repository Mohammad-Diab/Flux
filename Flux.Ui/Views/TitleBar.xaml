<UserControl x:Class="Flux.Ui.Views.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:views="clr-namespace:Flux.Ui.Views"
             x:Name="Root" Height="46" Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
            <!-- Back (system-style, top-left) — shown only on a nested page such as Settings. -->
            <Button x:Name="BackButton" Style="{StaticResource CaptionButton}" VerticalAlignment="Center"
                    Command="{Binding BackCommand, ElementName=Root}" ToolTip="Back" Margin="0,0,4,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Visibility="{Binding ShowBackButton, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>

            <views:BrandMark Width="22" Height="22" VerticalAlignment="Center" Margin="6,0,0,0"
                             Glyph="{Binding BrandGeometry, ElementName=Root}"/>
            <TextBlock Text="{Binding Title, ElementName=Root}" Margin="10,0,0,0" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding Subtitle, ElementName=Root}" Margin="10,0,0,0" VerticalAlignment="Center"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="SettingsButton" Style="{StaticResource CaptionButton}"
                    Command="{Binding SettingsCommand, ElementName=Root}" ToolTip="Settings"
                    Visibility="{Binding ShowSettingsButton, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
            <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Click="OnMinimize" ToolTip="Minimize">
                <Rectangle Width="12" Height="1" Fill="{StaticResource CaptionGlyphBrush}" SnapsToDevicePixels="True"/>
            </Button>
            <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="OnMaximize" ToolTip="Maximize">
                <Grid>
                    <Rectangle x:Name="MaxGlyph" Width="11" Height="11" Stroke="{StaticResource CaptionGlyphBrush}" StrokeThickness="1" SnapsToDevicePixels="True"/>
                    <Grid x:Name="RestoreGlyph" Width="12" Height="12" Visibility="Collapsed">
                        <Rectangle Width="8" Height="8" Stroke="{StaticResource CaptionGlyphBrush}" StrokeThickness="1"
                                   HorizontalAlignment="Right" VerticalAlignment="Top" SnapsToDevicePixels="True"/>
                        <Rectangle Width="8" Height="8" Stroke="{StaticResource CaptionGlyphBrush}" StrokeThickness="1"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom" SnapsToDevicePixels="True"/>
                    </Grid>
                </Grid>
            </Button>
            <Button x:Name="CloseButton" Style="{StaticResource CloseCaptionButton}" Click="OnClose" ToolTip="Close">
                <!-- Stroke follows the button Foreground so hover flips the X to white on red. -->
                <Path Data="M0,0 L11,11 M11,0 L0,11" StrokeThickness="1.3"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
