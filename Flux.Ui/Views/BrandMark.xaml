<UserControl x:Class="Flux.Ui.Views.BrandMark"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <!-- Vector brand mark (crisp at any DPI): gradient square + app-specific arrow. -->
    <Viewbox>
        <Grid Width="22" Height="22">
            <Border CornerRadius="6" Background="{StaticResource AccentGradient}"/>
            <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="{Binding Glyph, ElementName=Root}" Fill="White"/>
            </Viewbox>
        </Grid>
    </Viewbox>
</UserControl>
