<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Flux.Ui.Controls"
                    xmlns:converters="clr-namespace:Flux.Ui.Converters">

    <!-- Color tokens (dark defaults); ThemeService swaps them for light. Brushes bind via DynamicResource so they retint live and BAML can't freeze them. -->
    <Color x:Key="TextPrimaryColor">#EEF1F7</Color>
    <Color x:Key="TextSecondaryColor">#9BA6B8</Color>
    <Color x:Key="BorderColor">#2A3140</Color>
    <Color x:Key="SurfaceColor">#181C27</Color>
    <Color x:Key="SurfaceAltColor">#1F2434</Color>
    <Color x:Key="ButtonHoverOverlayColor">#FFFFFFFF</Color>
    <Color x:Key="HoverOverlayColor">#14FFFFFF</Color>
    <Color x:Key="HoverOverlayStrongColor">#22FFFFFF</Color>
    <Color x:Key="AltRowColor">#0DFFFFFF</Color>
    <Color x:Key="ScrollThumbColor">#3A4152</Color>
    <Color x:Key="ScrollThumbHoverColor">#5A657D</Color>
    <Color x:Key="CaptionGlyphColor">#D6DAE3</Color>
    <Color x:Key="BgColor1">#0C0E14</Color>
    <Color x:Key="BgColor2">#12151F</Color>
    <Color x:Key="BgColor3">#161A27</Color>

    <!-- Invariant brand + status colors (same in both themes). -->
    <Color x:Key="AccentColor">#7C5CFF</Color>
    <Color x:Key="DangerColor">#FF5C6C</Color>
    <Color x:Key="SuccessColor">#38D39F</Color>

    <LinearGradientBrush x:Key="BgBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource BgColor1}" Offset="0"/>
        <GradientStop Color="{DynamicResource BgColor2}" Offset="0.55"/>
        <GradientStop Color="{DynamicResource BgColor3}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Theme-varying brushes: colors via DynamicResource so they retint live and never freeze. -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="ButtonHoverOverlayBrush" Color="{DynamicResource ButtonHoverOverlayColor}"/>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="{DynamicResource HoverOverlayColor}"/>
    <SolidColorBrush x:Key="HoverOverlayStrongBrush" Color="{DynamicResource HoverOverlayStrongColor}"/>
    <SolidColorBrush x:Key="AltRowBrush" Color="{DynamicResource AltRowColor}"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="{DynamicResource ScrollThumbColor}"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="{DynamicResource ScrollThumbHoverColor}"/>
    <SolidColorBrush x:Key="CaptionGlyphBrush" Color="{DynamicResource CaptionGlyphColor}"/>

    <!-- Invariant brushes (frozen is fine — never retinted). -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#337C5CFF"/>
    <SolidColorBrush x:Key="DangerSelectionBrush" Color="#33FF5C6C"/>

    <!-- The signature Flux gradient: blue -> violet -> magenta (the "optical spectrum"). -->
    <GradientStopCollection x:Key="SpectrumStops">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#7C5CFF" Offset="0.5"/>
        <GradientStop Color="#C13BFF" Offset="1"/>
    </GradientStopCollection>
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1"
                         GradientStops="{StaticResource SpectrumStops}"/>
    <LinearGradientBrush x:Key="AccentGradientHorizontal" StartPoint="0,0" EndPoint="1,0"
                         GradientStops="{StaticResource SpectrumStops}"/>

    <DropShadowEffect x:Key="SoftShadow" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.45" Color="#000000"/>

    <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>

    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    <converters:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    <converters:InverseBoolConverter x:Key="InverseBool"/>

    <!-- Ambient-orb layer opacity; ThemeService dims it on light backgrounds. -->
    <sys:Double x:Key="AmbientOpacity">1</sys:Double>

    <!-- Shared motion gate; animated templates bind their Motion.Enabled to this instance. -->
    <controls:MotionSettings x:Key="MotionSettings"/>

    <!-- Shared taskbar progress; windows bind TaskbarItemInfo to it, view models push updates. -->
    <controls:TaskbarProgress x:Key="TaskbarProgress"/>

    <!-- ============ Sizing tokens (one control height everywhere) ============ -->
    <sys:Double x:Key="ControlHeight">40</sys:Double>
    <sys:Double x:Key="CtaHeight">46</sys:Double>

    <!-- ============ Typography ============ -->
    <!-- No Foreground: text inherits the window's, so Foreground="White" on buttons/tabs wins. -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="DisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
        <Setter Property="FontSize" Value="30"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="HeadingText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Centered, oversized brand wordmark painted with the spectrum gradient. -->
    <Style x:Key="BrandTitle" TargetType="TextBlock" BasedOn="{StaticResource DisplayText}">
        <Setter Property="FontSize" Value="46"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGradientHorizontal}"/>
    </Style>

    <Style x:Key="SubtleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ============ Buttons (animated: lift on hover, press-scale) ============ -->
    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="controls:Motion.Enabled" Value="{Binding AnimationsEnabled, Source={StaticResource MotionSettings}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        <Border x:Name="Overlay" CornerRadius="10" Background="{StaticResource ButtonHoverOverlayBrush}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover lift: animated when motion is on; instant overlay when off. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                         To="0.10" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Overlay" Property="Opacity" Value="0.10"/>
                        </MultiTrigger>
                        <!-- Press-shrink only when motion is on (no instant scale-jump when off). -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Flat muted fill reads as disabled better than a faded gradient. -->
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MinHeight" Value="{StaticResource CtaHeight}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="26,0"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Ghost danger action: red text at rest, solid red fill with white text on hover. -->
    <Style x:Key="DangerGhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Red fill fades in on hover; explicit TextBlock brush (its own instance, so the
                             animation never mutates the shared DangerBrush) cross-fades red -> white. -->
                        <Border x:Name="Fill" CornerRadius="8" Background="{StaticResource DangerBrush}" Opacity="0"/>
                        <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" Margin="{TemplateBinding Padding}"
                                   FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{StaticResource DangerColor}"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Fill + text cross-fade when motion is on; instant swap when off. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="Txt" To="White" Duration="0:0:0.15"
                                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Fill" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="Txt" To="{StaticResource DangerColor}" Duration="0:0:0.2"
                                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Fill" Property="Opacity" Value="1"/>
                            <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}"/>

    <!-- Icon caption buttons (title bar); Tag="Close" switches the hover treatment to system red. -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.FontFamily="Segoe MDL2 Assets"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayStrongBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Tag" Value="Close"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
        <Setter Property="Foreground" Value="{StaticResource CaptionGlyphBrush}"/>
        <Setter Property="Tag" Value="Close"/>
    </Style>

    <!-- ============ Inputs ============ -->
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="controls:Motion.Enabled" Value="{Binding AnimationsEnabled, Source={StaticResource MotionSettings}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Track" Width="40" Height="22" CornerRadius="11" VerticalAlignment="Center"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Border x:Name="OnFill" CornerRadius="11" Margin="-1" Opacity="0"
                                        Background="{StaticResource AccentBrush}"/>
                                <Border x:Name="Knob" Width="16" Height="16" CornerRadius="8"
                                        HorizontalAlignment="Left" Margin="3,0,0,0"
                                        Background="{StaticResource TextSecondaryBrush}">
                                    <Border.RenderTransform>
                                        <TranslateTransform/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- Knob turns white when on (instant; a color, not motion). -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Knob" Property="Background" Value="White"/>
                        </Trigger>
                        <!-- On: slide the knob and fade in the accent fill — animated when motion is on. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Knob"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="16" Duration="0:0:0.16" EasingFunction="{StaticResource EaseOut}"/>
                                        <DoubleAnimation Storyboard.TargetName="OnFill" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.16"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Knob"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.16" EasingFunction="{StaticResource EaseOut}"/>
                                        <DoubleAnimation Storyboard.TargetName="OnFill" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <!-- On, motion off: jump straight to the end state. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                            <Setter TargetName="OnFill" Property="Opacity" Value="1"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dark tooltip (default WPF tooltip is light, which hides our near-white text). -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="10,6" Effect="{StaticResource SoftShadow}">
                        <ContentPresenter TextElement.Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Card ============ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <!-- ============ Tabs (pill) ============ -->
    <Style x:Key="TabRadio" TargetType="RadioButton">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Padding="16,9" CornerRadius="9" Background="Transparent">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentGradientHorizontal}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Slim scrollbar (hover brightens, drag = accent) ============ -->
    <Style x:Key="FluxScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd" CornerRadius="4" Margin="2" Background="{StaticResource ScrollThumbBrush}"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="5">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource FluxScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton x:Name="IncreaseBtn" Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton x:Name="DecreaseBtn" Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                        </Trigger>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="10"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            <Setter TargetName="IncreaseBtn" Property="Command" Value="ScrollBar.PageRightCommand"/>
                            <Setter TargetName="DecreaseBtn" Property="Command" Value="ScrollBar.PageLeftCommand"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ProgressBar (accent gradient) ============ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGradientHorizontal}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="controls:Motion.Enabled" Value="{Binding AnimationsEnabled, Source={StaticResource MotionSettings}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid ClipToBounds="True">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}"/>
                        <!-- PART_Track required: WPF sizes PART_Indicator against it, else no fill. -->
                        <Border x:Name="PART_Track"/>
                        <Border x:Name="PART_Indicator" CornerRadius="4" HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"/>
                        <Border x:Name="Pulse" CornerRadius="4" Opacity="0" Background="{StaticResource AccentBrush}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Opacity" Value="0"/>
                        </Trigger>
                        <!-- Breathing pulse when motion is on; a static bar when off. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsIndeterminate" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard Name="PulseSb">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Pulse" Storyboard.TargetProperty="Opacity"
                                                         From="0.25" To="0.9" Duration="0:0:0.9"
                                                         EasingFunction="{x:Null}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="PulseSb"/>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsIndeterminate" Value="True"/>
                                <Condition Property="controls:Motion.Enabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Pulse" Property="Opacity" Value="0.55"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ComboBox (dark) ============ -->
    <Style x:Key="ComboToggle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                              Data="M0,0 L4,4 L8,0" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.4"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="controls:Motion.Enabled" Value="{Binding AnimationsEnabled, Source={StaticResource MotionSettings}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Style="{StaticResource ComboToggle}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" Margin="12,0,28,0"
                                          VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Slide">
                            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Margin="0,4,0,0" Effect="{StaticResource SoftShadow}"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer MaxHeight="260">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="controls:Motion.Enabled" Value="False">
                            <Setter TargetName="PART_Popup" Property="PopupAnimation" Value="None"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,2">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayStrongBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ListBox items (hover + active/selected) ============ -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                            Padding="{TemplateBinding Padding}" Margin="0,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                        </Trigger>
                        <!-- Mouse-down selects the item; the accent tint is the active/pressed state. -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectionBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ DataGrid (dark) ============ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource AltRowBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                        </Trigger>
                        <!-- Full-row selection marks every cell IsSelected → whole row tints on click. -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectionBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Borderless window chrome ============ -->
    <Style x:Key="FluxWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="False"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6" CornerRadius="0"
                                    GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
